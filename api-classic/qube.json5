{
  $schema: "https://q64.dev/schema/qube.json5",
  // Qube names are snake_case dotted segments — no dashes (the folder may use a
  // dash, the name may not).
  name: "qubepods.examples.api_classic",
  version: "0.1.0",
  license: "MIT OR Apache-2.0",
  description: "A classic request/response HTTP API — one @http_handler that stores records in the key-value store, queries the SQLite database, and stashes blobs in object storage. Capability-bounded: it never names a bucket, database, or namespace.",

  // An application qube. `qube run` builds this and serves it; `qube deploy`
  // ships it to qubepods, which serves it at a per-qube HTTPS endpoint. There is
  // no qubepod.jsonc, no deploy.sh, no wrangler — one manifest, two commands.
  type: "application",
  entry: "src/main.q",

  // Serve HTTP: lift the @http_handler into the WASI HTTP proxy world. The core
  // module exports a plain function; this component wrapper is what makes it an
  // HTTP handler (env.md §"HTTP service entry point"). No store is bound here —
  // the component only targets wasi:http/proxy; the host opens KV/SQL/blob.
  component: {
    emit: true,
    world: "api-classic",
    worlds: ["wasi:http/proxy"],
  },

  // What the API reaches — documented here, cross-checked against the source at
  // build/publish. Storage is NOT a manifest binding: there is no field that
  // names a KV namespace, a database, or a bucket. The qube declares only the
  // *effects* it uses; qubepods opens each store and pins it to this qube's
  // identity (org/project/app) at boot, and meters the guarded calls. That
  // capability boundary is the whole point — the app's data can't leak to
  // another tenant, enforced by the runtime, not by convention.
  effects: {
    declared: ["@kv", "@db", "@blob", "@network"],
  },
}
