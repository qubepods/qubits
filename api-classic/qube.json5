{
  $schema: "https://q64.dev/schema/qube.json5",
  // Qube names are snake_case dotted segments — no dashes (the folder may use a
  // dash, the name may not).
  name: "qubepods.examples.api_classic",
  version: "0.1.0",
  license: "MIT OR Apache-2.0",
  description: "A classic HTTP API worker — a plain JS request handler (no wasm on the server) that stores records in the key-value store, queries the light-fast SQLite database, and stashes blobs in object storage. Bindings come from this manifest; it never names a namespace, database, or bucket.",

  // Your qubepods project slug (a deploy token is pinned to its project).
  project: "api-classic",

  // A CLASSIC worker qube: `component.module` names a hand-written JS handler
  // (`export default { fetch }`) that runs as-is — no q64 compile, no wasm on the
  // server. (A q64 qube would instead set `entry` + `component.emit`; the twin
  // example does that.) `qube deploy` packs this module; `qube run` serves it.
  //
  // Two commands, same in the qubepods web shell and a terminal — no qubepod.jsonc,
  // no wrangler, no deploy script:
  //   qube run       serve it locally with the three stores bound.
  //   qube deploy    ship it to qubepods; it gets a per-qube HTTPS endpoint.
  component: {
    module: "src/index.js",
  },

  // Stateless: request-scoped, the persistence is the bound stores.
  runtime: "stateless",

  // The worker serves its own test page + JSON endpoints from `/`.
  exports: {
    http: { interface: "qubepods:http/handler", route: "/" },
  },

  // The stores this API reaches — the ONLY place bindings come from. qubepods opens
  // each store and pins it to this qube's identity (org/project/app), then injects
  // it under a fixed reserved name (never a namespace/database/bucket id):
  //
  //   cache   -> env.KV      key-value — this project's Durable Object (KV gateway)
  //   database-> env.DB      SQLite    — the SAME project DO's SQLite (SQL gateway)
  //   storage -> env.BUCKET  object store — this project's R2 bucket
  //
  // One store of each PER PROJECT, under reserved names — so the twin app in the
  // same project binds the SAME stores and shares this exact data. `tier:
  // "light-fast"` is the project Durable Object's SQLite (same durable as env.KV);
  // the other tiers are "replicated" (a dedicated D1) and "external" (BYO via
  // Hyperdrive). Pinned at project creation, immutable.
  imports: {
    cache: [{ name: "stats-kv", interface: "wasi:keyvalue/store" }],
    database: [{ name: "stats-db", interface: "qubepods:sql/database", tier: "light-fast" }],
    storage: [{ name: "assets", interface: "wasi:blobstore/blobstore" }],
  },
}
