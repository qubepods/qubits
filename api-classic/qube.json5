{
  $schema: "https://q64.dev/schema/qube.json5",
  name: "qubepods.examples.api_classic",
  version: "0.1.0",
  license: "MIT OR Apache-2.0",
  description: "A classic HTTP API worker — a plain JS request handler (no wasm on the server) that stores records in the key-value store, queries the light-fast SQLite database, and stashes blobs in object storage. Bindings come from this manifest; it never names a namespace, database, or bucket.",

  project: "api-classic",

  type: "application",

  component: {
    language: "javascript",
    module: "src/index.js",
  },

  runtime: "stateless",

  exports: {
    http: { interface: "qubepods:http/handler", route: "/" },
  },

  imports: {
    cache: [{ name: "stats-kv", interface: "wasi:keyvalue/store" }],
    database: [{ name: "stats-db", interface: "qubepods:sql/database", tier: "light-fast" }],
    storage: [{ name: "assets", interface: "wasi:blobstore/blobstore" }],
  },
}
