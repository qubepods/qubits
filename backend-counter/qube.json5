{
  $schema: "https://q64.dev/schema/qube.json5",
  name: "qubepods.examples.backend_counter",
  version: "0.1.0",
  license: "MIT OR Apache-2.0",
  description: "A shared click counter — the backend starter for qubepods. One backend per project, one shared count, every visitor sees the same number.",
  type: "application",
  entry: "src/main.q",

  // Serve as a per-qube HTTPS endpoint. The @http_handler export lowers to
  // the WASIp3 unified handler; qubepods runs it under generic Component
  // Model HTTP lifting (`wasmtime serve`) with no qubepods-specific ABI.
  component: {
    emit: true,
    world: "backend-counter",
    worlds: ["wasi:http/proxy"],
  },

  // The only capability this qube asks for: a key-value store (`env.kv`,
  // i.e. `wasi:keyvalue`). The host binds that import to the project's backend
  // store at boot, so the counter persists. `qube audit` shows exactly this
  // and nothing more — no network, no filesystem.
  effects: {
    declared: ["@kv"],
  },
}
