{
  $schema: "https://q64.dev/schema/qube.json5",
  name: "iot_thermo",
  version: "0.1.0",
  license: "MIT OR Apache-2.0",
  description: "Workspace root for the IoT starter — one project, three members: a device qube on your hardware, a backend qube on the platform, a frontend qube in the browser.",

  type: "workspace",

  workspace: {
    // `backend` is the deployable JS worker; `device` and `frontend` are q64
    // placeholder qubes that compile to valid wasm32 components today and
    // grow into the sensor actor / browser twin (see the README's
    // "Where this example is headed").
    members: ["device", "backend", "frontend"],
  },
}
