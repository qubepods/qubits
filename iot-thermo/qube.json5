{
  $schema: "https://q64.dev/schema/qube.json5",
  name: "iot_thermo",
  version: "0.1.0",
  license: "MIT OR Apache-2.0",
  description: "Workspace root for the IoT starter — one project, three members: a device qube on your hardware, a backend qube on the platform, a frontend qube in the browser.",

  type: "workspace",

  workspace: {
    // FOUR applications, the per-entity twin architecture: `device` runs on
    // the hardware; `device-twin` is its per-device backend twin (persists
    // readings to the project database); `backend` is the FLEET twin (the
    // frontend's single backend twin — fan-out); `frontend` is the stateless
    // aggregated dashboard (dynamic worker + project db + pushed updates).
    members: ["device", "device-twin", "backend", "frontend"],
  },
}
