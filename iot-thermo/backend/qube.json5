{
  $schema: "https://q64.dev/schema/qube.json5",
  name: "qubepods.examples.thermo",
  version: "0.2.0",
  license: "MIT OR Apache-2.0",
  description: "A live fleet thermometer — the IoT starter. The project's backend TWIN: devices stream SoC temperature up the node plane, the twin persists every reading into the project database via env.db and fans it out to every connected frontend. Deploys as its own stateful application — a deployment, not a route (see README.md).",

  project: "iot",

  // The twin is the project's ONE backend: exactly one instance, on the
  // platform, paired to every frontend socket and device reading by the
  // project itself. `runtime: "stateful"` is what routes the app's WebSocket
  // to the twin instead of a per-connection worker.
  type: "application",
  runtime: "stateful",

  entry: "src/twin.q",

  // `qube build --addr wasm32` emits the store-component CORE (`.kvcore`) —
  // the artifact the twin runtime instantiates (component-lift of raw env.*
  // is a tracked q64 gap). Requires q64 ≥ 0.0.11; ./deploy.sh builds and
  // ships it.
  build: "qube build --addr wasm32",
  component: {
    emit: true,
    world: "thermo-backend",
  },
  rpc: {
    export: true,
  },

  effects: {
    declared: ["@db", "@wire"],
  },
}
