{
  $schema: "https://q64.dev/schema/qube.json5",
  name: "qubepods.examples.stopwatch",
  version: "0.1.0",
  license: "MIT OR Apache-2.0",
  description: "A Qube binding two library qubes — clock (env.time) and adder (pure) — timing an add() call and printing the elapsed nanoseconds.",
  type: "application",
  entry: "src/main.q",

  dependencies: {
    "qubepods.examples.adder": { path: "../adder" },
    "qubepods.examples.clock": { path: "../clock" },
  },

  component: {
    emit: true,
    world: "stopwatch",
    worlds: ["wasi:cli/command"],
  },
}
