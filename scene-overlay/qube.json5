{
  "$schema": "https://q64.dev/schema/qube.json5",
  "name": "cube",
  "version": "0.0.0",
  "license": "MIT OR Apache-2.0",
  "description": "A QView form over a 3D scene — a turning cube (quine engine) behind a frosted card with a live counter. Links a sibling color library; declaring the quine engine dependency is what turns 3D on.",
  "type": "application",
  "entry": "main.q",
  "dependencies": {
    "test.color": { "path": "./color" },
    "com.qubeworlds.quine": "^0.1"
  },
  "game": {
    "scene": "scene.json",
    "assets": [
      { "name": "cube", "path": "assets/cube.glb" }
    ]
  }
}
