{
  $schema: "https://q64.dev/schema/qube.json5",
  name: "qubepods.examples.htmx_booking",
  version: "0.1.0",
  license: "MIT OR Apache-2.0",
  description: "A hypermedia (htmx) slot-booking app — the server renders HTML fragments, the browser swaps them in. Native <input type=\"date\"> as the date picker, no build step, no frontend framework; bookings live in the project's SQLite database via env.DB.",

  project: "edge",

  type: "application",

  component: {
    language: "javascript",
    module: "src/index.js",
  },

  runtime: "stateless",

  exports: {
    http: { interface: "qubepods:http/handler", route: "/" },
  },

  imports: {
    database: [{ name: "bookings-db", interface: "qubepods:sql/database", tier: "light-fast" }],
  },
}
