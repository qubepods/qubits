{
  $schema: "https://q64.dev/schema/qube.json5",
  name: "qubepods.examples.adder",
  version: "0.1.0",
  license: "MIT OR Apache-2.0",
  description: "The smallest q64 component — one scalar function, a + b.",
  type: "library",
  entry: "src/lib.q",

  component: {
    emit: true,
  },

  wit: {
    package: "qubepods-examples:adder",
    world: "adder",
    path: "synthesized",
  },
}
